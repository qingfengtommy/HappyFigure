# ── Google Gemini (API key auth) ──────────────────────────────────────
# GEMINI_API_KEY=your-gemini-api-key

# ── Google Vertex AI (service account auth, no API key needed) ────────
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Standard Azure OpenAI ────────────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# ── OpenAI ───────────────────────────────────────────────────────────
# OPENAI_API_KEY=your-openai-api-key

# ── Anthropic ────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ── AWS Bedrock ──────────────────────────────────────────────────────
# AWS_DEFAULT_REGION=us-east-1

# ── Optional: override Gemini model names ────────────────────────────
# GEMINI_MODEL_CHAT=gemini-3.1-pro-preview
# GEMINI_MODEL_CODE=gemini-3.1-pro-preview
# GEMINI_MODEL_DRAWING=gemini-3.1-flash-image-preview

# ── Optional: pipeline config overlay ────────────────────────────────
# HAPPYFIGURE_CONFIG=configs/pipeline_override.yaml
